# ── Databáze ────────────────────────────────────────────────────────────────
# Složka s SQLite soubory (global.db, <slug>.db, backups/)
DATA_DIR=/app/data

# ── Šifrování a session ──────────────────────────────────────────────────────
# AES-256-GCM klíč pro IMAP/SMTP hesla — 32 náhodných bajtů jako hex
# Generování: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# HMAC klíč pro podepisování session tokenů — 64 náhodných bajtů jako hex
SESSION_SECRET=change-me-generate-with-openssl-rand-hex-64

# ── SMTP (globální výchozí — přepisovatelné per-tenant) ──────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=change-me
SMTP_FROM=Kantýna <noreply@example.com>
ORDER_EMAIL_TO=kuchyne@example.com

# ── Telegram bot ─────────────────────────────────────────────────────────────
# Token z @BotFather
TELEGRAM_BOT_TOKEN=

# Tajný token pro ověření Telegram webhook requestů (libovolný řetězec)
TELEGRAM_WEBHOOK_SECRET=

# chat_id super admina pro Telegram alerty (disk, zálohy, chyby)
SUPER_ADMIN_TELEGRAM_CHAT_ID=

# ── Logování ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

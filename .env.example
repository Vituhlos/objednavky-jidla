# ── SSO / Auth (Auth.js / NextAuth v5) ──
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=https://kantyna.example.local
AUTH_TRUST_HOST=true

# Google OAuth (volitelné — pro přihlášení přes Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated admin emails (promoted to role=admin on login)
ADMIN_EMAILS=admin@example.com

# Telegram webhook secret is stored in DB (settings) after first save or auto-generate via Nastavení → Telegram

# ── SMTP ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=change-me
SMTP_FROM=STROS obedovy system <noreply@example.com>
ORDER_EMAIL_TO=jidelny@example.com

# ── Build metadata (set by CI/Docker, optional locally) ──
COMMIT_SHA=
BUILD_TIME=
GIT_REF=
